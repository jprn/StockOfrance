                </div>\
                <span style=\{\{ fontSize:14, fontWeight:800,\
                  color: h.type==="entree" ? css.success : css.danger \}\}>\
                  \{h.type==="entree" ? "+" : "\uc0\u8722 "\}\{h.qte\}\
