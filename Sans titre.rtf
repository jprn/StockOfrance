\
      <SectionTitle>Aujourd'hui</SectionTitle>\
      <div style=\{\{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:10, marginBottom:10 \}\}>\
        \{[\
          \{ val: attente.length, label: "En attente", color: css.primary \},\
          \{ val: livreesAujourdhui.length, label: "Livr\'e9es", color: css.success \},\
          \{ val: alertes.length, label: "Alertes stock", color: css.warn \},\
          \{ val: ruptures.length, label: "Ruptures", color: css.danger \},\
        ].map(s=>(\
          <div key=\{s.label\} style=\{\{ background:css.surface, borderRadius:14, padding:"16px 14px",\
            boxShadow:"0 1px 4px rgba(0,0,0,.06)" \}\}>\
            <div style=\{\{ fontSize:32, fontWeight:800, color:s.color, letterSpacing:-1, lineHeight:1 \}\}>\{s.val\}</div>\
            <div style=\{\{ fontSize:11, color:css.inkSoft, marginTop:4, fontWeight:500 \}\}>\{s.label\}</div>\
          </div>\
        ))\}\
      </div>\
\
      <SectionTitle>Actions rapides</SectionTitle>\
      <div style=\{\{ display:"flex", gap:10, marginBottom:6 \}\}>\
        \{[\
          \{ icon:"\uc0\u55357 \u56589 ", label:"Chercher commande", screen:"commandes" \},\
          \{ icon:"\uc0\u55357 \u56550 ", label:"Voir le stock",      screen:"stock" \},\
        ].map(q=>(\
          <div key=\{q.label\} onClick=\{()=>setScreen(q.screen)\}\
            style=\{\{ flex:1, background:css.surface, borderRadius:12, border:`1.5px solid $\{css.border\}`,\
              padding:"14px 10px", display:"flex", flexDirection:"column", alignItems:"center",\
              gap:6, fontSize:12, fontWeight:600, color:css.inkSoft, cursor:"pointer",\
              boxShadow:"0 1px 3px rgba(0,0,0,.05)" \}\}>\
            <span style=\{\{ fontSize:22 \}\}>\{q.icon\}</span>\{q.label\}\
