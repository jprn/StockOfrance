\
      <SectionTitle>Commandes en attente</SectionTitle>\
      \{attente.length === 0\
        ? <div style=\{\{ textAlign:"center", color:css.inkGhost, fontSize:14, padding:24 \}\}>Aucune commande en attente \uc0\u55356 \u57225 </div>\
        : attente.slice(0,3).map(cmd=>(\
          <OrderCard key=\{cmd.id\} cmd=\{cmd\} articles=\{articles\}\
